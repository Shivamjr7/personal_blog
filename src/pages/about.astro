---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutContent from '../content/about.mdx';
---

<BaseLayout
  title="About — Shivam Jari"
  description="About Shivam Jari."
>
  <div class="mx-auto max-w-[68ch] px-6 py-16">
    <header class="mb-10 font-sans">
      <h1 class="text-3xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        About
      </h1>
    </header>
    <article
      class="prose prose-neutral max-w-none
        prose-headings:font-sans prose-headings:font-semibold
        prose-code:font-mono prose-code:text-[0.875em]
        prose-pre:rounded-lg
        prose-a:text-terracotta-600 prose-a:no-underline hover:prose-a:underline
        [&_p]:font-serif [&_li]:font-serif [&_blockquote]:font-serif
        dark:prose-invert
        dark:prose-a:text-terracotta-400"
    >
      <AboutContent />
    </article>
  </div>
</BaseLayout>
