---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';

const books = (await getCollection('books')).sort(
  (a, b) => b.data.readAt.getTime() - a.data.readAt.getTime(),
);

const years = [...new Set(books.map(b => b.data.readAt.getFullYear()))];
const grouped = years.map(year => ({
  year,
  entries: books.filter(b => b.data.readAt.getFullYear() === year),
}));
---

<BaseLayout
  title="Bookshelf — Shivam Jari"
  description="Books I've read and recommend. Notes are mine, often incomplete."
>
  <div class="mx-auto max-w-[68ch] px-6 py-16" data-pagefind-body>
    <header class="mb-12">
      <h1 class="font-sans text-2xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        Bookshelf
      </h1>
      <p class="mt-2 font-serif text-neutral-500 dark:text-neutral-400">
        Books I've read and recommend. Notes are mine, often incomplete.
      </p>
    </header>

    {grouped.map(group => (
      <section class="mb-12">
        <h2 class="mb-5 font-sans text-xs font-semibold uppercase tracking-widest text-neutral-400 dark:text-neutral-500">
          {group.year}
        </h2>
        <ul class="grid grid-cols-1 gap-8 md:grid-cols-2">
          {group.entries.map(book => {
            const readAtFormatted = book.data.readAt.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'short',
              day: 'numeric',
            });
            const body = (
              <div class="flex gap-4">
                {book.data.coverImage && (
                  <Image
                    src={book.data.coverImage}
                    alt={`${book.data.title} cover`}
                    width={64}
                    height={96}
                    class="h-24 w-16 shrink-0 rounded-sm object-cover shadow-sm"
                  />
                )}
                <div class="min-w-0 flex-1">
                  <h3 class="font-sans text-[15px] font-semibold text-neutral-900 dark:text-neutral-100">
                    {book.data.title}
                  </h3>
                  <p class="mt-0.5 font-sans text-sm text-neutral-400 dark:text-neutral-500">
                    {book.data.author}
                  </p>
                  {book.data.notes && (
                    <p class="mt-2 font-serif text-[0.9375rem] leading-relaxed text-neutral-500 dark:text-neutral-400">
                      {book.data.notes}
                    </p>
                  )}
                  <div class="mt-3 flex items-center gap-2.5 font-sans text-xs text-neutral-400 dark:text-neutral-500">
                    <time datetime={book.data.readAt.toISOString()}>{readAtFormatted}</time>
                    {book.data.rating !== undefined && (
                      <>
                        <span aria-hidden>·</span>
                        <span>{book.data.rating}/5</span>
                      </>
                    )}
                  </div>
                </div>
              </div>
            );
            return (
              <li>
                {book.data.url ? (
                  <a
                    href={book.data.url}
                    target="_blank"
                    rel="noopener"
                    class="group block transition-colors"
                  >
                    {body}
                  </a>
                ) : (
                  body
                )}
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </div>
</BaseLayout>
