---
import BaseLayout from '../layouts/BaseLayout.astro';
import NowContent, { frontmatter } from '../content/now.mdx';

const { updatedAt } = frontmatter as { updatedAt: string };
const updatedDate = new Date(updatedAt);
const formattedDate = updatedDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout
  title="Now — Shivam Jari"
  description="What Shivam Jari is currently working on."
>
  <div class="mx-auto max-w-[68ch] px-6 py-16">
    <header class="mb-10 font-sans">
      <h1 class="text-3xl font-semibold tracking-tight text-neutral-900 dark:text-neutral-100">
        Now
      </h1>
      <p class="mt-3 text-sm text-neutral-400 dark:text-neutral-500">
        Last updated <time datetime={updatedDate.toISOString()}>{formattedDate}</time>
      </p>
    </header>
    <article
      class="prose prose-neutral max-w-none
        prose-headings:font-sans prose-headings:font-semibold
        prose-code:font-mono prose-code:text-[0.875em]
        prose-pre:rounded-lg
        prose-a:text-terracotta-600 prose-a:no-underline hover:prose-a:underline
        [&_p]:font-serif [&_li]:font-serif [&_blockquote]:font-serif
        dark:prose-invert
        dark:prose-a:text-terracotta-400"
    >
      <NowContent />
    </article>
  </div>
</BaseLayout>
