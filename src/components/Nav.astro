---
import ThemeToggle from './ThemeToggle.astro';

const links = [
  { href: '/posts',      label: 'Writing'    },
  { href: '/categories', label: 'Categories' },
  { href: '/about',      label: 'About'      },
  { href: '/now',        label: 'Now'        },
];

const pathname = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/90 backdrop-blur-sm dark:bg-neutral-950/90">
  <nav
    class="mx-auto flex max-w-[68ch] items-center justify-between px-6 py-4"
    aria-label="Main navigation"
  >
    <a
      href="/"
      class="font-sans text-sm font-semibold text-neutral-900 dark:text-neutral-100 hover:text-terracotta-600 dark:hover:text-terracotta-400 transition-colors duration-150"
    >
      Shivam Jari
    </a>

    <div class="flex items-center gap-1">
      {links.map(({ href, label }) => {
        const isActive = pathname === href || pathname.startsWith(href + '/');
        return (
          <a
            href={href}
            class:list={[
              'rounded px-2.5 py-1.5 font-sans text-sm transition-colors duration-150 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-terracotta-500',
              isActive
                ? 'text-terracotta-600 dark:text-terracotta-400 font-medium'
                : 'text-neutral-500 hover:text-neutral-900 dark:text-neutral-400 dark:hover:text-neutral-100',
            ]}
            aria-current={isActive ? 'page' : undefined}
          >
            {label}
          </a>
        );
      })}
      <button
        type="button"
        id="nav-search-trigger"
        aria-label="Search posts"
        class="flex items-center gap-1.5 rounded p-1.5 text-neutral-400 transition-colors hover:text-neutral-900 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-terracotta-500 dark:hover:text-neutral-100"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="18"
          height="18"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="7"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <kbd class="hidden rounded border border-neutral-200 bg-neutral-50 px-1 py-0.5 font-sans text-[10px] text-neutral-400 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-500 sm:inline-block">⌘K</kbd>
      </button>
      <ThemeToggle />
    </div>
  </nav>
</header>

<script>
  const trigger = document.getElementById('nav-search-trigger');
  trigger?.addEventListener('click', () => {
    (window as unknown as { openSearch?: () => void }).openSearch?.();
  });
</script>
