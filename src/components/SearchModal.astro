---
/*
 * Client-side search over posts, powered by Pagefind.
 *
 * Pagefind's index is generated by `pagefind --site dist` during production
 * builds (see package.json > scripts.build). It lives at /pagefind/pagefind.js
 * and is NOT available in `astro dev` — the modal shows a friendly dev-mode
 * message in that case.
 */
---

<div
  id="search-modal"
  class="fixed inset-0 z-[60] hidden"
  role="dialog"
  aria-modal="true"
  aria-labelledby="search-title"
  aria-hidden="true"
>
  <button
    id="search-backdrop"
    class="absolute inset-0 bg-black/40 backdrop-blur-sm"
    tabindex="-1"
    aria-label="Close search"
  ></button>

  <div
    id="search-dialog"
    class="relative mx-auto mt-0 h-full w-full max-w-xl overflow-hidden bg-white shadow-xl dark:bg-neutral-900 sm:mt-[15vh] sm:h-auto sm:rounded-lg sm:border sm:border-neutral-200 dark:sm:border-neutral-800"
  >
    <h2 id="search-title" class="sr-only">Search posts</h2>

    <div class="flex items-center gap-3 border-b border-neutral-200 px-4 py-3 dark:border-neutral-800">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18"
        height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="shrink-0 text-neutral-400"
        aria-hidden="true"
      >
        <circle cx="11" cy="11" r="7"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Search posts…"
        autocomplete="off"
        spellcheck="false"
        class="flex-1 bg-transparent font-sans text-[15px] text-neutral-900 placeholder:text-neutral-400 focus:outline-none dark:text-neutral-100 dark:placeholder:text-neutral-500"
        aria-label="Search posts"
        aria-controls="search-results"
        aria-autocomplete="list"
        aria-activedescendant=""
      />
      <kbd class="hidden shrink-0 rounded border border-neutral-200 bg-neutral-50 px-1.5 py-0.5 font-sans text-[11px] text-neutral-400 dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-500 sm:inline-block"
        >esc</kbd
      >
    </div>

    <div id="search-status" class="sr-only" aria-live="polite" aria-atomic="true"></div>

    <div class="max-h-[calc(100vh-8rem)] overflow-y-auto sm:max-h-[60vh]">
      <ul id="search-results" role="listbox" aria-label="Search results" class="py-1"></ul>

      <p id="search-empty" class="px-4 py-10 text-center font-sans text-sm text-neutral-400 dark:text-neutral-500">
        Start typing to search posts.
      </p>
      <p
        id="search-noresults"
        class="hidden px-4 py-10 text-center font-sans text-sm text-neutral-400 dark:text-neutral-500"
      >
        No posts match "<span id="search-noresults-query"></span>".
      </p>
      <p
        id="search-unavailable"
        class="hidden px-4 py-10 text-center font-sans text-sm text-neutral-400 dark:text-neutral-500"
      >
        Search index isn't built in dev. Run <code class="font-mono text-[13px] text-neutral-500 dark:text-neutral-400">pnpm build &amp;&amp; pnpm preview</code>.
      </p>
    </div>

    <div
      class="hidden items-center gap-4 border-t border-neutral-200 px-4 py-2 font-sans text-[11px] text-neutral-400 dark:border-neutral-800 dark:text-neutral-500 sm:flex"
    >
      <span class="flex items-center gap-1">
        <kbd class="rounded border border-neutral-200 bg-neutral-50 px-1 py-0.5 dark:border-neutral-700 dark:bg-neutral-800">↑</kbd>
        <kbd class="rounded border border-neutral-200 bg-neutral-50 px-1 py-0.5 dark:border-neutral-700 dark:bg-neutral-800">↓</kbd>
        navigate
      </span>
      <span class="flex items-center gap-1">
        <kbd class="rounded border border-neutral-200 bg-neutral-50 px-1 py-0.5 dark:border-neutral-700 dark:bg-neutral-800">⏎</kbd>
        open
      </span>
      <span class="flex items-center gap-1">
        <kbd class="rounded border border-neutral-200 bg-neutral-50 px-1 py-0.5 dark:border-neutral-700 dark:bg-neutral-800">esc</kbd>
        close
      </span>
    </div>
  </div>
</div>

<style>
  /* Pagefind's excerpt contains <mark> — style inline. */
  #search-results mark {
    background-color: var(--color-terracotta-100);
    color: inherit;
    border-radius: 2px;
    padding: 0 2px;
  }
  :global(.dark) #search-results mark {
    background-color: color-mix(in oklab, var(--color-terracotta-900) 50%, transparent);
  }
  /* When modal is open, lock background scroll. */
  :global(body.search-open) {
    overflow: hidden;
  }
</style>

<script>
  interface PagefindMeta {
    title?: string;
    description?: string;
    category?: string;
    date?: string;
    tags?: string;
  }
  interface PagefindResultData {
    url: string;
    excerpt: string;
    meta: PagefindMeta;
  }
  interface PagefindResult {
    id: string;
    data(): Promise<PagefindResultData>;
  }
  interface PagefindSearchResponse {
    results: PagefindResult[];
  }
  interface PagefindAPI {
    options(opts: Record<string, unknown>): Promise<void>;
    init(): Promise<void>;
    preload(query: string): void;
    debouncedSearch(
      query: string,
      options?: Record<string, unknown>,
      debounceMs?: number,
    ): Promise<PagefindSearchResponse | null>;
  }

  const modal = document.getElementById('search-modal') as HTMLDivElement;
  const backdrop = document.getElementById('search-backdrop') as HTMLButtonElement;
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results') as HTMLUListElement;
  const empty = document.getElementById('search-empty') as HTMLParagraphElement;
  const noResults = document.getElementById('search-noresults') as HTMLParagraphElement;
  const noResultsQuery = document.getElementById('search-noresults-query') as HTMLSpanElement;
  const unavailable = document.getElementById('search-unavailable') as HTMLParagraphElement;
  const status = document.getElementById('search-status') as HTMLDivElement;

  let pagefind: PagefindAPI | null = null;
  let pagefindLoadAttempted = false;
  let lastOpener: HTMLElement | null = null;
  let selectedIndex = -1;
  let currentResults: Array<{ url: string; id: string }> = [];

  async function loadPagefind(): Promise<PagefindAPI | null> {
    if (pagefind) return pagefind;
    if (pagefindLoadAttempted) return null;
    pagefindLoadAttempted = true;
    try {
      // /pagefind/pagefind.js is generated post-build by `pagefind --site dist`.
      // Via a variable so Vite can't statically resolve it at dev-transform time.
      const pagefindUrl = '/pagefind/pagefind.js';
      const mod = (await import(/* @vite-ignore */ pagefindUrl)) as PagefindAPI;
      await mod.options({ excerptLength: 28 });
      await mod.init();
      pagefind = mod;
      return mod;
    } catch {
      return null;
    }
  }

  function openModal(opener: HTMLElement | null) {
    lastOpener = opener;
    modal.classList.remove('hidden');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('search-open');
    input.value = '';
    resetResults();
    // Kick off pagefind init in the background while the user focuses.
    loadPagefind().then(api => {
      if (!api) unavailable.classList.remove('hidden');
      empty.classList.toggle('hidden', !api);
    });
    requestAnimationFrame(() => input.focus());
  }

  function closeModal() {
    modal.classList.add('hidden');
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('search-open');
    lastOpener?.focus();
    lastOpener = null;
  }

  function resetResults() {
    results.innerHTML = '';
    currentResults = [];
    selectedIndex = -1;
    input.setAttribute('aria-activedescendant', '');
    noResults.classList.add('hidden');
    unavailable.classList.add('hidden');
    empty.classList.remove('hidden');
    status.textContent = '';
  }

  function formatDate(iso: string | undefined): string {
    if (!iso) return '';
    const d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '';
    return d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  function renderResults(items: PagefindResultData[]) {
    results.innerHTML = '';
    currentResults = [];
    selectedIndex = -1;
    input.setAttribute('aria-activedescendant', '');

    if (items.length === 0) {
      empty.classList.add('hidden');
      noResultsQuery.textContent = input.value;
      noResults.classList.remove('hidden');
      status.textContent = 'No results';
      return;
    }

    empty.classList.add('hidden');
    noResults.classList.add('hidden');
    status.textContent = `${items.length} result${items.length === 1 ? '' : 's'}`;

    items.forEach((item, i) => {
      const id = `search-result-${i}`;
      const li = document.createElement('li');
      li.id = id;
      li.setAttribute('role', 'option');
      li.setAttribute('aria-selected', 'false');
      li.dataset.url = item.url;
      li.className = 'cursor-pointer px-4 py-3 font-sans';

      const meta = document.createElement('div');
      meta.className =
        'mb-1 flex items-center gap-2 text-[11px] uppercase tracking-widest text-neutral-400 dark:text-neutral-500';
      const cat = document.createElement('span');
      cat.className = 'text-terracotta-600 dark:text-terracotta-400 font-medium';
      cat.textContent = item.meta.category ?? '';
      meta.appendChild(cat);
      const date = formatDate(item.meta.date);
      if (date) {
        const dot = document.createElement('span');
        dot.setAttribute('aria-hidden', 'true');
        dot.textContent = '·';
        const time = document.createElement('span');
        time.textContent = date;
        meta.appendChild(dot);
        meta.appendChild(time);
      }

      const title = document.createElement('div');
      title.className = 'text-[15px] font-semibold text-neutral-900 dark:text-neutral-100';
      title.textContent = item.meta.title ?? '';

      const excerpt = document.createElement('p');
      excerpt.className = 'mt-1 text-[13px] leading-relaxed text-neutral-500 dark:text-neutral-400';
      // excerpt is sanitized HTML from Pagefind (<mark> highlights only)
      excerpt.innerHTML = item.excerpt;

      li.appendChild(meta);
      li.appendChild(title);
      li.appendChild(excerpt);

      li.addEventListener('mouseenter', () => setSelected(i));
      li.addEventListener('mousedown', e => {
        e.preventDefault();
        window.location.href = item.url;
      });

      results.appendChild(li);
      currentResults.push({ url: item.url, id });
    });

    setSelected(0);
  }

  function setSelected(index: number) {
    if (index < 0 || index >= currentResults.length) return;
    const prev = results.querySelector<HTMLLIElement>('[aria-selected="true"]');
    if (prev) {
      prev.setAttribute('aria-selected', 'false');
      prev.classList.remove('bg-neutral-100', 'dark:bg-neutral-800');
    }
    selectedIndex = index;
    const el = document.getElementById(currentResults[index].id) as HTMLLIElement | null;
    if (el) {
      el.setAttribute('aria-selected', 'true');
      el.classList.add('bg-neutral-100', 'dark:bg-neutral-800');
      el.scrollIntoView({ block: 'nearest' });
      input.setAttribute('aria-activedescendant', el.id);
    }
  }

  async function onInput() {
    const query = input.value.trim();
    if (!query) {
      resetResults();
      return;
    }
    const api = await loadPagefind();
    if (!api) {
      empty.classList.add('hidden');
      noResults.classList.add('hidden');
      unavailable.classList.remove('hidden');
      return;
    }
    api.preload(query);
    const response = await api.debouncedSearch(query, {}, 120);
    if (!response) return; // superseded
    const top = await Promise.all(response.results.slice(0, 8).map(r => r.data()));
    renderResults(top);
  }

  // Global keyboard listeners
  document.addEventListener('keydown', e => {
    const isOpen = !modal.classList.contains('hidden');

    // Open shortcuts: Cmd+K / Ctrl+K / '/'
    if (!isOpen) {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        openModal(document.activeElement as HTMLElement);
        return;
      }
      if (e.key === '/' && !isEditableTarget(e.target)) {
        e.preventDefault();
        openModal(document.activeElement as HTMLElement);
        return;
      }
      return;
    }

    // Modal is open
    if (e.key === 'Escape') {
      e.preventDefault();
      closeModal();
      return;
    }
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (currentResults.length === 0) return;
      setSelected((selectedIndex + 1) % currentResults.length);
      return;
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (currentResults.length === 0) return;
      setSelected((selectedIndex - 1 + currentResults.length) % currentResults.length);
      return;
    }
    if (e.key === 'Enter') {
      if (selectedIndex < 0 || !currentResults[selectedIndex]) return;
      e.preventDefault();
      const url = currentResults[selectedIndex].url;
      if (e.metaKey || e.ctrlKey) {
        window.open(url, '_blank', 'noopener');
      } else {
        window.location.href = url;
      }
      return;
    }
    if (e.key === 'Tab') {
      // Keep focus inside the modal — the input is the only interactive target.
      e.preventDefault();
      input.focus();
    }
  });

  function isEditableTarget(t: EventTarget | null): boolean {
    if (!(t instanceof HTMLElement)) return false;
    const tag = t.tagName;
    return (
      tag === 'INPUT' ||
      tag === 'TEXTAREA' ||
      tag === 'SELECT' ||
      t.isContentEditable
    );
  }

  input.addEventListener('input', onInput);
  backdrop.addEventListener('click', closeModal);

  // Expose an opener so Nav.astro can wire buttons without re-implementing shortcuts
  (window as unknown as { openSearch: () => void }).openSearch = () => {
    openModal(document.activeElement as HTMLElement);
  };
</script>
