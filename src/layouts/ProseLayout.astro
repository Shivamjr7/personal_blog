---
import '../styles/global.css';

interface Props {
  frontmatter: {
    title?: string;
  };
}

const { frontmatter } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{frontmatter?.title ?? 'Post'}</title>
  </head>
  <body class="bg-white text-stone-900 antialiased">
    <main class="mx-auto max-w-[68ch] px-6 py-16">
      <article class="prose prose-stone max-w-none
        prose-headings:font-sans prose-headings:font-semibold
        prose-code:font-mono prose-code:text-[0.875em]
        prose-pre:rounded-lg
        prose-a:text-terracotta-600 prose-a:no-underline hover:prose-a:underline
        [&_p]:font-serif [&_li]:font-serif [&_blockquote]:font-serif">
        <slot />
      </article>
    </main>
  </body>
</html>
